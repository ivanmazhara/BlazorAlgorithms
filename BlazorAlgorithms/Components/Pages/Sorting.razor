@page "/sorting"
@using BlazorAlgorithms.utils
@rendermode InteractiveServer

<h1><b>Sorting Algorithms</b></h1>

<p>Sorting algorithms are used to rearrange a given array or list of elements in an order. For example, a given array [10, 20, 5, 2] becomes [2, 5, 10, 20] after sorting in increasing order and becomes [20, 10, 5, 2] after sorting in decreasing order.
</p>

<h4>Sort-Check</h4>
<input @bind="SortCheckInput" placeholder="Enter numbers (e.g., 1,2,3)" style="width: 250px;" />
<button @onclick="RunSortCheck">Check</button>
<p><strong>Result:</strong> @SortCheckMessage</p>

@code {
    private string SortCheckInput { get; set; } = "";
    private string SortCheckMessage { get; set; } = "";

    private void RunSortCheck()
    {
        var result = ArrayUtility.ParseArray(SortCheckInput);
        if (result.Numbers == null)
        {
            SortCheckMessage = result.ErrorMessage;
            return;
        }

        SortCheckMessage = IsSorted(result.Numbers) ? "The array is sorted!" : "The array is not sorted.";
    }
    
    private static bool IsSorted(int[] arr)
    {
        for (int i = 0; i < arr.Length - 1; i++) {
            if (arr[i] > arr[i + 1]) return false;
        }
        return true;
    }

}

<h4>Bubble Sort</h4>
<input @bind="BubbleSortInput" placeholder="Enter numbers (e.g., 1,2,3)" style="width: 250px;" />
<button @onclick="RunBubbleSort">Sort</button>
<p><strong>Sorted: </strong>@BubbleSortMessage</p>

@if (BubbleSortHistory != null && BubbleSortHistory.Any())
{
    <table class="algo-table">
        <thead>
        <tr>
            <th>Step</th>
            <th>Outer (i)</th>
            <th>Inner (j)</th>
            <th>Array State</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var step in BubbleSortHistory)
        {
            <tr>
                <td>@step.iteration</td>
                <td>@step.i</td>
                <td>@step.j</td>
                <td class="algo-array-cell">

                    @for (int index = 0; index < step.arr.Length; index++)
                    {
                        bool isActive = (index == step.j || index == step.j + 1);
                        
                        <span class="algo-element @(isActive ? "active" : "")">
                                @step.arr[index]
                            </span>
                    }

                </td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private string BubbleSortInput = "";
    private string BubbleSortMessage = "";
    private List<BubbleSortStep> BubbleSortHistory = new();
    
    private void RunBubbleSort()
    {
        var result = ArrayUtility.ParseArray(BubbleSortInput);
        if (result.Numbers == null)
        {
            BubbleSortMessage = result.ErrorMessage;
            return;
        }

        int[] benchmarkArray = result.Numbers.ToArray();
        
        var watch = System.Diagnostics.Stopwatch.StartNew();
        int[] sorted = BubbleSort(benchmarkArray);
        watch.Stop();
        var elapsedMs = watch.Elapsed.TotalMilliseconds;

        BubbleSortHistory = HistoryBubbleSort(result.Numbers);
        
        BubbleSortMessage = "[" + string.Join(", ", sorted) + "]; " + $"\nExecuted in: {elapsedMs} ms."; 
    }

    private record BubbleSortStep(int iteration, int[] arr, int i, int j);

    private static int[] BubbleSort(int[] arr)
    {
        int temp;
        for (int i = 0; i < arr.Length; i++) {
            for (int j = 0; j < arr.Length - 1; j++) {
                if(arr[j+1] < arr[j]){
                    temp = arr[j+1];
                    arr[j+1] = arr[j];
                    arr[j] = temp;
                }
            }
        }
        return arr;
    }
    
    private static List<BubbleSortStep> HistoryBubbleSort(int[] arr)
    {
        var history = new List<BubbleSortStep>();
        
        int[] workArray = arr.ToArray();
        int stages = 0;
        int temp;
        
        for (int i = 0; i < workArray.Length; i++) {
            for (int j = 0; j < workArray.Length - 1; j++) {
                if(workArray[j+1] < workArray[j]){
                    temp = workArray[j+1];
                    workArray[j+1] = workArray[j];
                    workArray[j] = temp;
                }
                
                history.Add(new BubbleSortStep(stages, workArray.ToArray(), i, j));
                stages++;
            }
        }

        return history;
    }
}

<h4>Selection Sort</h4>
<input @bind="SelectionSortInput" placeholder="Enter numbers (e.g., 1,2,3)" style="width: 250px;" />
<button @onclick="RunSelectionSort">Sort</button>
<p><strong>Sorted: </strong>@SelectionSortMessage</p>

@if (SelectionSortHistory != null && SelectionSortHistory.Any())
{

    <table class="algo-table">
        <thead>
        <tr>
            <th>Step</th>
            <th>Outer (i)</th>
            <th>Inner (j)</th>
            <th>Minimal Element Index</th>
            <th>Array State</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var step in SelectionSortHistory)
        {
            <tr>
                <td>@step.iteration</td>
                <td>@step.i</td>
                <td>@step.j</td>
                <td>@step.minIndex</td>
                <td class="algo-array-cell">
                    @for (int index = 0; index < step.arr.Length; index++)
                    {
                        bool isActive = (index == step.j || index == step.minIndex);

                        bool isSorted = index < step.i;

                        <span class="algo-element @(isActive ? "active" : "")" style="@(isSorted ? "color: #aaa;" : "")">
                            @step.arr[index]
                        </span>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private string SelectionSortInput = "";
    private string SelectionSortMessage = "";
    private List<SelectionSortStep> SelectionSortHistory = new();
    
    private void RunSelectionSort()
    {
        var result = ArrayUtility.ParseArray(SelectionSortInput);
        if (result.Numbers == null)
        {
            SelectionSortMessage = result.ErrorMessage;
            return;
        }

        int[] benchmarkArray = result.Numbers.ToArray();
        
        var watch = System.Diagnostics.Stopwatch.StartNew();
        int[] sorted = SelectionSort(benchmarkArray);
        watch.Stop();
        var elapsedMs = watch.Elapsed.TotalMilliseconds;
        
        SelectionSortHistory = HistorySelectionSort(result.Numbers);
        SelectionSortMessage = "[" + string.Join(", ", sorted) + "]; " + $"\nExecuted in: {elapsedMs} ms."; 
    }
    
    public static int[] SelectionSort(int[] arr) 
    {
        for (int i = 0; i < arr.Length - 1; i++) {
            int minIndex = i;
            for (int j = i + 1; j < arr.Length; j++) {
                if (arr[j] < arr[minIndex]) {
                    minIndex = j;
                }
            }
            (arr[i], arr[minIndex]) = (arr[minIndex], arr[i]);
        }
        return arr;
    }

    private record SelectionSortStep(int iteration, int[] arr, int i, int j, int minIndex);
    private List<SelectionSortStep> HistorySelectionSort(int[] arr)
    {
        var history = new List<SelectionSortStep>();
    
        int[] workArray = arr.ToArray();
        int stages = 0;
        
        for (int i = 0; i < workArray.Length - 1; i++) {
            int minIndex = i;
        
            for (int j = i + 1; j < workArray.Length; j++) {
                if (workArray[j] < workArray[minIndex]) {
                    minIndex = j;
                }
                
                history.Add(new SelectionSortStep(stages, workArray.ToArray(), i, j, minIndex));
                stages++;
            }

            (workArray[i], workArray[minIndex]) = (workArray[minIndex], workArray[i]);
            history.Add(new SelectionSortStep(stages, workArray.ToArray(), i, i, minIndex));
            stages++;
        }
    
        return history;
    }
}


<h4>Insertion Sort</h4>
<input @bind="InsertionSortInput" placeholder="Enter numbers (e.g., 1,2,3)" style="width: 250px;" />
<button @onclick="RunInsertionSort">Sort</button>
<p><strong>Sorted: </strong>@InsertionSortMessage</p>

@code {
    private string InsertionSortInput = "";
    private string InsertionSortMessage = "";
    
    private void RunInsertionSort()
    {
        var result = ArrayUtility.ParseArray(InsertionSortInput);
        if (result.Numbers == null)
        {
            InsertionSortMessage = result.ErrorMessage;
            return;
        }
        
        var watch = System.Diagnostics.Stopwatch.StartNew();
        int[] sorted = InsertionSort(result.Numbers);
        watch.Stop();
        var elapsedMs = watch.Elapsed.TotalMilliseconds;
        
        InsertionSortMessage = "[" + string.Join(", ", sorted) + "]; " + $"\nExecuted in: {elapsedMs} ms."; 
    }

    private static int[] InsertionSort(int[] arr)
    {
        for (int i = 1; i < arr.Length; i++)
        {
            int key = arr[i]; 
            int j = i - 1;
            while (j >= 0 && arr[j] > key)
            {
                arr[j + 1] = arr[j];
                j--;
            }
            arr[j + 1] = key;
        }
        return arr;
    }
}